# Cloudflare Pages / Workers Static Assets — Cache Rules
# HTML: always revalidate so visitors get updates immediately.
# Assets: long-lived since filenames don't change often.

/
  Cache-Control: no-cache, no-store, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  X-Content-Type-Options: nosniff

# CSS + JS: 1-week cache — update filenames when content changes
/assets/css/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/assets/js/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Images / SVGs: 30-day cache — these rarely change
/assets/img/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# Fonts (self-hosted, if ever added): 1-year immutable
/assets/css/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Misc static files
/robots.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400

/humans.txt
  Cache-Control: public, max-age=86400
